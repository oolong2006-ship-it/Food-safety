# Anthropic API Key — server-side only, never expose to the client
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model (haiku is default for cost/speed)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL=claude-sonnet-4-6

# App URL (for PWA manifest, OG tags, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
